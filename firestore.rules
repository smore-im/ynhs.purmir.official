rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 공지사항: 누구나 읽기, 인증된 관리자만 쓰기 ──
    match /notices/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── 행사: 누구나 읽기, 인증된 관리자만 쓰기 ──
    match /events/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── 건의함: 누구나 읽기/작성, 수정은 likes·comments 필드만, 삭제는 관리자만 ──
    match /posts/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['title','body','date','privacy','cat'])
                    && request.resource.data.title is string
                    && request.resource.data.title.size() <= 200;
      // 일반 사용자: likes·comments 필드만 수정 허용
      allow update: if !request.auth != null
                    && request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['likes','comments']);
      // 관리자: 모든 필드 수정 가능 (답변, 공개전환 등)
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── 투표/설문: 누구나 읽기, 참여(update)는 total·questions만, 관리자는 전체 ──
    match /votes/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      // 일반 사용자: total·questions 필드만 수정 허용 (투표 참여)
      allow update: if !request.auth != null
                    && request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['total','questions','participants']);
      // 관리자: 마감·재개 등 전체 수정 가능
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── 갤러리: 누구나 읽기, 인증된 관리자만 쓰기 ──
    match /gallery/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── FAQ: 누구나 읽기, 인증된 관리자만 쓰기 ──
    match /faqs/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── 예산: 누구나 읽기, 인증된 관리자만 쓰기 ──
    match /budget/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── 학생 DB: 설문 참여 시 create만, 읽기/수정/삭제는 관리자만 ──
    match /students/{id} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.keys().hasAll(['sno','name'])
                    && request.resource.data.sno is string
                    && request.resource.data.sno.size() <= 20;
      allow update, delete: if request.auth != null;
    }
  }
}
